meta {
  name: Get Sessions With Pagination
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/sessions?page=1&limit=5
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

assert {
  res.status: eq 200
  res.body.success: eq true
  res.body.data: isArray
  res.body.pagination: isDefined
}
