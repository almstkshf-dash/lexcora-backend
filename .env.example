# ====================================
# LEXCORA BACKEND ENVIRONMENT VARIABLES
# ====================================
# Copy this file to .env and update with actual values

# ========== NODE ENVIRONMENT ==========
NODE_ENV=production
PORT=8080

# ========== JWT AUTHENTICATION ==========
# Generate secure random strings for both secrets (min 32 characters)
# Example: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_here_change_in_production
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here_change_in_production
JWT_REFRESH_EXPIRES_IN=7d

# ========== DATABASE (RAILWAY MYSQL) ==========
# These credentials come from your Railway MySQL instance
# Format: mysql://user:password@host:port/database
DB_HOST=your-railway-host.railway.app
DB_PORT=3306
DB_NAME=lexcora
DB_USER=root
DB_PASSWORD=your_database_password_here
SLOW_REQUEST_MS=1000

# ========== FILE STORAGE (CLOUDFLARE R2) ==========
# Replace AWS credentials with Cloudflare R2 API token credentials
AWS_ACCESS_KEY_ID=your_r2_access_key_id
AWS_SECRET_ACCESS_KEY=your_r2_secret_access_key
AWS_REGION=auto
AWS_S3_BUCKET_NAME=lexcora
S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# Optional: Set to 'true' if R2 bucket is configured for public access
AWS_S3_USE_PUBLIC_URL=false
# If AWS_S3_USE_PUBLIC_URL=true, set the public URL base
# AWS_S3_PUBLIC_URL=https://your-public-r2-url.com

# ========== CORS & FRONTEND URLs ==========
# Comma-separated list of allowed origins for CORS
CORS_ORIGINS=http://localhost:3000,https://lexcora-frontend.vercel.app,https://lexcora-client-portal.vercel.app
# Fallback frontend URL for backward compatibility
FRONTEND_URL=https://lexcora-frontend.vercel.app

# ========== OPENAI INTEGRATION (Legal Assistant) ==========
OPENAI_API_KEY=your_openai_api_key_here

# ========== DEPLOYMENT & MONITORING ==========
# Optional: Build/deployment identifiers for monitoring
# BUILD_ID=your_build_id
# GIT_COMMIT=your_commit_hash
